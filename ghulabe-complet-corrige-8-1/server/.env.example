# ==============================================================================
# GHULABE — CONFIGURATION ENVIRONNEMENT PRODUCTION (LWS PARIS / SUPABASE EU)
# Données hébergées strictement en France / UE (Conformité Loi Gabonaise & RGPD)
# ==============================================================================

# 1. SUPABASE EU & POSTGRESQL (Région : eu-west-3 Paris / eu-central-1)
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-secret-key"
DATABASE_URL="postgresql://postgres:your-db-password@db.your-project-id.supabase.co:5432/postgres?sslmode=require"

# 2. SÉCURITÉ & AUTHENTIFICATION JWT (Expiration 24h & 2FA obligatoire)
JWT_SECRET="ghulabe_super_secret_jwt_key_2026_master_pme_africa"
JWT_EXPIRES_IN="24h"
JWT_ISSUER="ghulabe.com"

# 3. CHIFFREMENT AU REPOS (AES-256)
AES_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef" # Clé hex 32 bytes (256 bits)
AES_IV_LENGTH="16"

# 4. REDIS (Cache temps réel & Scans en cours & Rate Limiting Strict)
REDIS_URL="redis://default:your-redis-password@redis.lws.fr:6379"

# 5. SERVEUR & RESEAU
PORT="5000"
NODE_ENV="production"
CORS_ALLOWED_ORIGIN="https://ghulabe.com"

# 6. MOTEUR DE SCAN (Binaire Nuclei & Nmap)
NUCLEI_BINARY_PATH="/usr/local/bin/nuclei"
NMAP_BINARY_PATH="/usr/bin/nmap"
SSL_LABS_API_URL="https://api.ssllabs.com/api/v3"
SECURITY_HEADERS_API_URL="https://securityheaders.com"

# 7. ANALYSE IA DES SCANS (Gemini)
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.5-flash"

# 8. ENVOI DU CODE 2FA PAR EMAIL (SMTP)
# Compatible avec une boîte mail LWS, Gmail, Brevo ou tout compte SMTP standard.
SMTP_HOST="smtp.lws-hosting.com"
SMTP_PORT="587"
SMTP_USER="noreply@ghulabe.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM_EMAIL="noreply@ghulabe.com"
SMTP_FROM_NAME="GHULABE Sécurité"
